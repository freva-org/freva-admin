[Unit]
Description=Freva Web Redis server
After=network.target
{% if not ansible_become %}
ConditionHost={{ ansible_hostname }}
{% endif %}

[Service]
Type=simple
PermissionsStartOnly=true
NoNewPrivileges=true
KillSignal=SIGTERM
ExecStart={{ bash_cmd }}  {{conda_path}}/bin/start-freva-service -s redis
Environment="PATH={{conda_path}}/bin:{{ ansible_env.PATH }}"
StandardOutput=journal
StandardError=journal
EnvironmentFile={{ env_dir }}/redis.env
Restart=on-failure
RestartSec=5
StartLimitBurst=5
UMask=007
ReadWritePaths={{conda_path }}
{% if (ansible_become == true and ansible_become_user == 'root') or ansible_user == 'root' %}
ProtectHome=true
ProtectSystem=full
User={{uid}}
Group={{gid}}
{% endif %}
[Install]
WantedBy=multi-user.target
